{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LectureScribe",
  "version": "0.1.0",
  "identifier": "com.lecturescribe.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LectureScribe",
        "width": 1500,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
